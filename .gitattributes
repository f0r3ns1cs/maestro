# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.cpp text diff=cpp
*.h text diff=cpp
*.hpp text diff=cpp

# Project / build files
*.sln text eol=crlf
*.slnx text eol=crlf
*.vcxproj text eol=crlf
*.filters text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf

# Documentation
*.md text diff=markdown
LICENSE text

# Config
.editorconfig text
.gitattributes text
.gitignore text

# Binary
*.exe binary
*.dll binary
*.pdb binary
